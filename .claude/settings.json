{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(composer *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(php *)",
      "Read(./.env.example)",
      "Edit(./.env.example)",
      "mcp__laravel-boost*",
      "mcp__chrome-devtools*",
      "mcp__linear-server*"
    ],
    "ask": [
      "Edit(./CLAUDE.md)",
      "Edit(./CLAUDE.project.md)",
      "Edit(./.claude/settings.json)",
      "Edit(./.claude/settings.local.json)",
      "Edit(./.claude/agents/**)",
      "Edit(./.claude/hooks/**)",
      "Write(./.claude/agents/**)",
      "Write(./.claude/hooks/**)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./auth.json)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/reset-session-state.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/record-edit.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/record-verification.sh"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "session_start|compact|path_glob_match|nested_traversal|include",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/log-instructions-loaded.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/inject-implementation-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/require-verification-before-stop.sh"
          }
        ]
      }
    ]
  }
}
